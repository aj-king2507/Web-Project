{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "array",
  "items": {
    "type": "object",
    "properties": {
      "appointment_id": { "type": "integer" },

      "start_datetime": { "type": "string" },
      "end_datetime": { "type": "string" },
      "status": { "type": "string" },
      "notes": { "type": ["string", "null"] },

      "customer_first": { "type": "string" },
      "customer_last": { "type": "string" },

      "therapist_first": { "type": "string" },
      "therapist_last": { "type": "string" },

      "service_name": { "type": "string" },
      "price": { "type": "number" }
    },
    "required": [
      "appointment_id",
      "start_datetime",
      "end_datetime",
      "status",
      "customer_first",
      "customer_last",
      "therapist_first",
      "therapist_last",
      "service_name",
      "price"
    ]
  }
}
